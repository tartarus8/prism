# Telegram Bot Token (obtain from @BotFather on Telegram)
BOT_TOKEN=your_telegram_bot_token_here

# Yandex Music Account Token (Optional, public URLs can be fetched anonymously)
YANDEX_MUSIC_TOKEN=optional_yandex_music_token_here

# Simulated size of download in MB (to test Telegram's 50MB bot upload limits)
# Set to > 50.0 (e.g. 55.0) to test the warning message for large files
MOCK_FILE_SIZE_MB=15.0

# Directory to save downloaded files temporarily before uploading
DOWNLOAD_DIR=downloads
